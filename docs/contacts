<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Autonomy Assistant</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="/static/css/styles.css" rel="stylesheet">
</head>
<body>

    <nav class="navbar navbar-expand-md navbar-dark bg-dark mb-4 shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold text-info" href="/">☀️ Autonomy</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarCollapse">
                <ul class="navbar-nav ms-auto mb-2 mb-md-0">
                    <li class="nav-item">
                        <a class="nav-link fs-5 px-3" href="/">🏠 Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fs-5 px-3" href="/medications">💊 Medications</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fs-5 px-3" href="/contacts">📞 Emergency Contacts</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container px-3">
        
<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

        <h1 class="fw-bold mb-4">📞 Emergency Contacts</h1>

        <div class="dashboard-card mb-4 shadow-sm">
            <h3 class="fw-bold text-secondary mb-3">Add New Contact</h3>

            <form id="contact-form">
                <div class="mb-3">
                    <label for="contact-name" class="form-label fw-bold">Full Name</label>
                    <input type="text" class="form-control form-control-lg" id="contact-name" placeholder="e.g., John Doe" required>
                </div>

                <div class="mb-3">
                    <label for="contact-relationship" class="form-label fw-bold">Relationship</label>
                    <input type="text" class="form-control form-control-lg" id="contact-relationship" placeholder="e.g., Son, Doctor, Neighbor" required>
                </div>

                <div class="mb-4">
                    <label for="contact-phone" class="form-label fw-bold">Phone Number</label>
                    <input type="tel" class="form-control form-control-lg" id="contact-phone" placeholder="e.g., +54291xxxxxxx" required>
                </div>

                <button type="submit" class="btn btn-primary btn-accessible">
                    💾 Save Contact
                </button>
            </form>
        </div>

        <h3 class="fw-bold text-secondary mb-3">Emergency Directory</h3>
        <div id="contacts-list">
            </div>

    </div>
</div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script src="/static/js/database.js"></script>
    <script src="/static/js/alerts.js"></script>
</body>
</html>